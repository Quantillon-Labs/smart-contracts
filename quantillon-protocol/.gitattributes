# =============================================================================
# QUANTILLON PROTOCOL - GIT ATTRIBUTES
# =============================================================================
#
# This file specifies which files git-crypt encrypts.
# WHY: Keep sensitive deployment scripts encrypted in a public repo, while leaving
#      all CI/analysis tooling readable so GitHub Actions can execute it without the
#      git-crypt key. (An encrypted .sh checks out as a binary blob in CI and fails
#      with "cannot execute binary file".)
#
# Policy: encrypt ONLY the deployment scripts (the sole secret-bearing location).
# Everything else under scripts/ (CI gates, analysis, docs, scenarios, utils) stays
# plaintext. Secrets in environment files are handled by the repo-root .gitattributes.
# =============================================================================

scripts/deployment/** filter=git-crypt diff=git-crypt
