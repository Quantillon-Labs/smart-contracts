{
  "filter_paths": "^lib/|^test/|^out/|^cache/|^node_modules/|^src/mocks/",
  "exclude_informational": false,
  "exclude_low": false,
  "exclude_medium": false,
  "exclude_high": false,
  "solc_args": "--optimize --via-ir",
  "solc_remaps": [
    "forge-std/=lib/forge-std/src/",
    "openzeppelin/=lib/openzeppelin-contracts/",
    "ozu/=lib/openzeppelin-contracts-upgradeable/"
  ]
}
